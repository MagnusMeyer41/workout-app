generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ──────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────

enum OrgRole {
  CLUB_ADMIN
}

enum TeamRole {
  COACH
  PLAYER
}

enum ProgramType {
  STRENGTH
  SPORT_SPECIFIC
}

enum WorkoutStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum NotificationType {
  PROGRAM_ASSIGNED
  WORKOUT_DUE
  SESSION_REVIEWED
}

// ──────────────────────────────────────────────────
// Auth models (NextAuth)
// ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  orgMemberships     OrgMembership[]
  teamMemberships    TeamMembership[]
  coachedPrograms    Program[]           @relation("ProgramCoach")
  programAssignments ProgramAssignment[]
  trainingSessions   TrainingSession[]
  benchmarks         Benchmark[]
  notifications      Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────────
// Organisation & team
// ──────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams           Team[]
  orgMemberships  OrgMembership[]
  programs        Program[]
  exercises       Exercise[]
  benchmarkDefs   BenchmarkDefinition[]
}

/// Org-level membership — role CLUB_ADMIN only for now
model OrgMembership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole  @default(CLUB_ADMIN)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Team {
  id             String   @id @default(cuid())
  name           String
  slug           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships  TeamMembership[]
  programs     Program[]

  @@unique([organizationId, slug])
}

model TeamMembership {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  role     TeamRole @default(PLAYER)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

// ──────────────────────────────────────────────────
// Exercise library
// ──────────────────────────────────────────────────

/// organizationId null = global (visible to all orgs)
model Exercise {
  id             String   @id @default(cuid())
  name           String
  category       String
  defaultUnit    String   @default("kg")
  organizationId String?
  createdAt      DateTime @default(now())

  organization      Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  muscles           ExerciseMuscle[]
  exerciseTemplates ExerciseTemplate[]
  exerciseLogs      ExerciseLog[]
}

model Muscle {
  id   String @id @default(cuid())
  name String @unique

  exercises ExerciseMuscle[]
}

model ExerciseMuscle {
  exerciseId String
  muscleId   String
  isPrimary  Boolean @default(false)

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle   Muscle   @relation(fields: [muscleId], references: [id], onDelete: Cascade)

  @@id([exerciseId, muscleId])
}

/// organizationId null = global platform default
model BenchmarkDefinition {
  id             String  @id @default(cuid())
  name           String
  unit           String  @default("kg")
  organizationId String?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  benchmarks   Benchmark[]
  setTemplates SetTemplate[]
}

// ──────────────────────────────────────────────────
// Programs
// ──────────────────────────────────────────────────

model Program {
  id             String      @id @default(cuid())
  name           String
  description    String?
  type           ProgramType
  coachId        String
  organizationId String
  teamId         String?
  isTemplate     Boolean     @default(false)
  isPublished    Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  coach        User                @relation("ProgramCoach", fields: [coachId], references: [id])
  organization Organization        @relation(fields: [organizationId], references: [id])
  team         Team?               @relation(fields: [teamId], references: [id])
  assignments  ProgramAssignment[]
  weeks        ProgramWeek[]
}

model ProgramWeek {
  id         String   @id @default(cuid())
  programId  String
  weekNumber Int
  createdAt  DateTime @default(now())

  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  days    WorkoutDay[]
}

model WorkoutDay {
  id        String   @id @default(cuid())
  weekId    String
  dayNumber Int
  name      String
  notes     String?
  createdAt DateTime @default(now())

  week              ProgramWeek        @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exerciseTemplates ExerciseTemplate[]
  scheduledWorkouts ScheduledWorkout[]
}

model ExerciseTemplate {
  id           String  @id @default(cuid())
  workoutDayId String
  exerciseId   String
  order        Int
  notes        String?

  workoutDay   WorkoutDay    @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exercise     Exercise      @relation(fields: [exerciseId], references: [id])
  setTemplates SetTemplate[]
}

model SetTemplate {
  id                    String  @id @default(cuid())
  exerciseTemplateId    String
  setNumber             Int
  targetReps            Int
  targetWeight          Float?
  targetWeightPercent   Float?
  benchmarkDefinitionId String?
  restSeconds           Int     @default(60)
  notes                 String?

  exerciseTemplate ExerciseTemplate     @relation(fields: [exerciseTemplateId], references: [id], onDelete: Cascade)
  benchmarkDef     BenchmarkDefinition? @relation(fields: [benchmarkDefinitionId], references: [id])
}

// ──────────────────────────────────────────────────
// Assignments & scheduling
// ──────────────────────────────────────────────────

model ProgramAssignment {
  id          String    @id @default(cuid())
  programId   String
  playerId    String
  startDate   DateTime
  isSynced    Boolean   @default(true)
  assignedAt  DateTime  @default(now())
  completedAt DateTime?

  program           Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  player            User              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  scheduledWorkouts ScheduledWorkout[]

  @@unique([programId, playerId])
}

model ScheduledWorkout {
  id                  String        @id @default(cuid())
  workoutDayId        String
  programAssignmentId String
  scheduledDate       DateTime
  status              WorkoutStatus @default(SCHEDULED)

  workoutDay        WorkoutDay        @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  programAssignment ProgramAssignment @relation(fields: [programAssignmentId], references: [id], onDelete: Cascade)
  trainingSessions  TrainingSession[]
}

// ──────────────────────────────────────────────────
// Training log
// ──────────────────────────────────────────────────

model TrainingSession {
  id                 String        @id @default(cuid())
  userId             String
  scheduledWorkoutId String?
  date               DateTime
  notes              String?
  status             WorkoutStatus @default(SCHEDULED)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledWorkout ScheduledWorkout? @relation(fields: [scheduledWorkoutId], references: [id])
  exerciseLogs     ExerciseLog[]
}

model ExerciseLog {
  id                String   @id @default(cuid())
  trainingSessionId String
  exerciseId        String
  order             Int
  notes             String?
  createdAt         DateTime @default(now())

  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  exercise        Exercise        @relation(fields: [exerciseId], references: [id])
  setLogs         SetLog[]
}

model SetLog {
  id            String  @id @default(cuid())
  exerciseLogId String
  setNumber     Int
  reps          Int?
  weight        Float?
  unit          String? @default("kg")
  rpe           Float?
  completed     Boolean @default(false)

  exerciseLog ExerciseLog @relation(fields: [exerciseLogId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────
// Benchmarks
// ──────────────────────────────────────────────────

model Benchmark {
  id                    String   @id @default(cuid())
  userId                String
  benchmarkDefinitionId String
  value                 Float
  unit                  String?  @default("kg")
  recordedAt            DateTime @default(now())
  notes                 String?

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  benchmarkDefinition BenchmarkDefinition @relation(fields: [benchmarkDefinitionId], references: [id])
}

// ──────────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  read      Boolean          @default(false)
  payload   String           @default("{}")
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
